{
  "permissions": {
    "allow": [
      "Bash(npx create-next-app@latest . --typescript --tailwind --eslint --app --src-dir --import-alias \"@/*\" --no-git)",
      "PowerShell(Get-PSDrive C | Select-Object @{N='Used_GB';E={[math]::Round\\($_.Used/1GB,1\\)}}, @{N='Free_GB';E={[math]::Round\\($_.Free/1GB,1\\)}})",
      "PowerShell($drive = Get-PSDrive -Name C; Write-Host \"Free: $\\([math]::Round\\($drive.Free/1MB,0\\)\\) MB\")",
      "Bash(npm cache *)",
      "PowerShell(Get-ChildItem *)",
      "PowerShell(Remove-Item *)",
      "Bash(npm install *)",
      "Bash(npm run *)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000)"
    ]
  }
}
